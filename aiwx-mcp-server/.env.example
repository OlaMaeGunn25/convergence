# CONVERGENCE-Ai MCP server configuration
# The gateway (aiwx-smb-auditor) REST base URL
GATEWAY_URL=http://localhost:3003
# The admin orchestrator (tenant provisioning + HITL queue) base URL
ADMIN_URL=http://localhost:8080
# Operator API key — must match the gateway's GATEWAY_API_KEY so calls are
# authenticated and audit-logged. Required in production.
GATEWAY_API_KEY=

# =============================================================================
# CONVERGENCE-Ai — environment configuration template
# Copy to .env for local dev, or inject these as container/host env vars in
# production. NO secrets belong in source control or image layers.
# =============================================================================

# --- Gateway (aiwx-smb-auditor/server.js) ------------------------------------
PORT=3003
NODE_ENV=production
LOG_LEVEL=info

# Required at boot — the server exits if any of these are missing
FIRECRAWL_API_KEY=fc-your-key-here
GA4_PROPERTY_ID=123456789
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 service-account credentials (choose ONE):
# 1) Base64 of the full service-account JSON — preferred in cloud, never hits disk:
#    powershell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials-ga.json"))
#    bash:       base64 -w0 credentials-ga.json
GA4_CREDENTIALS_BASE64=
# 2) Or a path to the JSON file (mounted secret volume):
#GA4_CREDENTIALS_PATH=/run/secrets/credentials-ga.json

# --- Supabase (Sales Command Center CRM export) ------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional tuning
#SUPABASE_POOL_SIZE=10
#SUPABASE_MAX_RETRIES=3
#SUPABASE_REQUEST_TIMEOUT_MS=15000

# --- Workspace layout (defaults work in the Docker image and local checkout) --
#CONVERGENCE_ROOT=/app
#SOCIAL_AGENT_DIR=/app/aiwx-social-media-agent
#ADMIN_DIST_DIR=/app/aiwx-admin-agent/dist

# --- CORS / limits -------------------------------------------------------------
# Extra allowed origins, comma-separated (exact match)
#CORS_ALLOWED_ORIGINS=https://app.convergence-ai.com
#RATE_LIMIT_GLOBAL_PER_MIN=120
#JSON_BODY_LIMIT=2mb

# --- Puppeteer (set automatically inside the Docker image) --------------------
#PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# --- Admin middleware (aiwx-admin-agent/server) — only if you run it ----------
#JWT_SECRET=
#ENCRYPTION_KEY=
#DEFAULT_VAULT_KEY=
#GCP_PROJECT=
#GCP_LOCATION=us-central1
#N8N_WEBHOOK_URL=
#QUICKBOOKS_CLIENT_ID=
#APP_URL=

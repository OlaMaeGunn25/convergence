# SMB External Audit Engine Configuration

# Port to run the local Express server on
PORT=3000

# Firecrawl API Key (from https://firecrawl.dev)
# Leave blank or omit to run in high-fidelity mock/simulator mode for instant, free demonstrations
FIRECRAWL_API_KEY=

# Google Scholar (SerpApi) — Legal Services vertical
# Powers case-law search, expert-witness publication vetting, and scientific-precedent checks.
# Get a key at https://serpapi.com. Leave blank to use the simulated fallback dataset.
# SCHOLAR_API_KEY is accepted as an alias.
SERPAPI_API_KEY=

# ── Campaign / queue stores ──────────────────────────────────────────────────
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, the campaign
# scheduler, activity alerts, and audit queue are stored in Supabase with
# row-level locking. When they are unset, the stores fall back to the JSON files
# under config/ — intended for local dev only: the fallback's lock is
# process-local, so it does not protect against two Node processes (for example
# server.js and scheduler_daemon.js) writing at once.

# Hold PENDING campaign posts for human release in the shared hitl_queue instead
# of auto-approving them. Requires Supabase. Default: false (legacy behaviour).
CAMPAIGN_HITL_APPROVAL=false

# Tenant to attribute campaign HITL tasks to (optional).
# CAMPAIGN_TENANT_ID=

# Minutes after which a post stuck in PUBLISHING, or an audit job stuck in
# running, is assumed to belong to a crashed worker and is returned to the queue.
STALE_JOB_MINUTES=30

{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "prefer-const": "warn",
    "semi": ["error", "always"],
    "no-empty": "warn",
    "no-prototype-builtins": "off",
    "no-useless-escape": "off"
  }
}

# CONVERGENCE-Ai™ Environment Variables Template
PORT=8080

# JSON Web Token Secret (used for signing activation tokens)
JWT_SECRET=your_high_entropy_jwt_secret_key_here

# Supabase Configurations
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# AES-256 Encryption Key (Exactly 32 characters for credential vault)
ENCRYPTION_KEY=your_32_character_aes_encryption_key

# Google Cloud Settings (Optional for local development)
GCP_PROJECT=aiwx-sandbox-prod-88
GCP_LOCATION=us-central1
